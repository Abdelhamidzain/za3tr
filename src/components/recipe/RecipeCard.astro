---
import ResponsiveImage from '../global/ResponsiveImage.astro';

interface Props {
  slug: string;
  title: string;
  titleJp?: string | null;
  image?: string | null;
  category?: string | null;
  difficulty?: string | null;
  prepTime?: number | null;
  cookTime?: number | null;
  totalTime?: number | null;
  avgRating?: number | null;
  reviewCount?: number | null;
}

const { slug, title, titleJp, image, category, difficulty, prepTime, cookTime, totalTime, avgRating, reviewCount } = Astro.props;

const placeholderImage = `https://placehold.co/600x400/F5E6D3/B85C38?text=${encodeURIComponent(title)}`;
const difficultyClass = difficulty === 'beginner' ? 'tag-difficulty-beginner' : difficulty === 'intermediate' ? 'tag-difficulty-intermediate' : 'tag-difficulty-advanced';
---

<a href={`/recipes/${slug}`} class="recipe-card block bg-white rounded-2xl overflow-hidden shadow-[var(--shadow-sm)] border border-[var(--color-border-light)]">
  <!-- Image -->
  <div class="relative aspect-[4/3] overflow-hidden bg-[var(--color-sand)]">
    <ResponsiveImage 
      src={image || placeholderImage} 
      alt={title}
      loading="lazy"
      class="w-full h-full object-cover"
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
      widths={[300, 400, 600]}
      quality={55}
    />
    
    {category && (
      <span class="absolute top-3 left-3 px-2.5 py-1 rounded-full text-xs font-medium bg-white/90 backdrop-blur-sm text-[var(--color-ink)] capitalize">
        {category}
      </span>
    )}
  </div>
  
  <!-- Content -->
  <div class="p-4">
    <h3 class="font-[family-name:var(--font-display)] text-lg font-bold text-[var(--color-ink)] leading-tight">
      {title}
    </h3>
    
    {titleJp && (
      <p class="text-sm text-[var(--color-text-muted)] text-jp mt-0.5">{titleJp}</p>
    )}
    
    <!-- Rating -->
    {avgRating && avgRating > 0 && (
      <div class="flex items-center gap-1.5 mt-2">
        <div class="flex">
          {[1,2,3,4,5].map(s => (
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill={s <= Math.round(avgRating) ? '#B45309' : 'none'} stroke="#B45309" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          ))}
        </div>
        <span class="text-xs text-[var(--color-text-light)]">{avgRating} ({reviewCount})</span>
      </div>
    )}
    
    <!-- Meta -->
    <div class="flex items-center gap-3 mt-2">
      {difficulty && (
        <span class:list={["tag", difficultyClass]}>{difficulty}</span>
      )}
      
      {totalTime && (
        <span class="flex items-center gap-1 text-xs text-[var(--color-text-light)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {totalTime} min
        </span>
      )}
    </div>
  </div>
</a>
