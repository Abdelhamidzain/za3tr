---
interface Props {
  name: string;
  description: string;
  image: string;
  prepTime: number;
  cookTime: number;
  totalTime: number;
  servings: number;
  category: string;
  calories?: number;
  ingredients: { amount: string; unit: string; name: string }[];
  steps: string[];
  slug: string;
}

const { name, description, image, prepTime, cookTime, totalTime, servings, category, calories, ingredients, steps, slug } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  "name": name,
  "description": description,
  "image": [image],
  "author": {
    "@type": "Organization",
    "name": "Za3tr"
  },
  "datePublished": new Date().toISOString().split('T')[0],
  "prepTime": `PT${prepTime}M`,
  "cookTime": `PT${cookTime}M`,
  "totalTime": `PT${totalTime}M`,
  "recipeYield": `${servings} servings`,
  "recipeCategory": category,
  "recipeCuisine": "Japanese",
  ...(calories ? { "nutrition": { "@type": "NutritionInformation", "calories": `${calories} calories` } } : {}),
  "recipeIngredient": ingredients.map(i => `${i.amount} ${i.unit} ${i.name}`.trim()),
  "recipeInstructions": steps.map((step, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "text": step
  })),
  "url": `https://za3tr.com/recipes/${slug}`
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
