---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  let data: any[] = [];
  try {
    const res = await supabase.from('comparison_pages').select('slug').eq('status', 'published');
    data = res.data || [];
  } catch (e) {}
  return data.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

let page: any = null;
try {
  const { data } = await supabase.from('comparison_pages').select('*').eq('slug', slug!).single();
  page = data;
} catch (e) {}

if (!page) return Astro.redirect('/404');

const faqs = page.faq_data || [];
---

<BaseLayout 
  title={page.title_en || `${page.item_a} vs ${page.item_b}`}
  description={page.meta_description_en || `Compare ${page.item_a} and ${page.item_b}. Learn the differences in taste, preparation, and when to use each.`}
>
  {faqs.length > 0 && <FAQSchema faqs={faqs} />}
  
  <article class="py-12 md:py-16">
    <div class="container content-width">
      <nav class="flex items-center gap-2 text-sm text-[var(--color-text-light)] mb-6">
        <a href="/" class="hover:text-[var(--color-terracotta)]">Home</a>
        <span>/</span>
        <span>Compare</span>
        <span>/</span>
        <span class="text-[var(--color-text-muted)]">{page.item_a} vs {page.item_b}</span>
      </nav>

      <h1 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">
        {page.title_en || `${page.item_a} vs ${page.item_b}`}
      </h1>

      {page.content_en && (
        <div class="mt-8 prose prose-lg max-w-none" set:html={page.content_en} />
      )}

      {faqs.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)] mb-6">FAQ</h2>
          <div class="space-y-4">
            {faqs.map((faq: any) => (
              <details class="bg-[var(--color-sand)]/40 rounded-xl p-5 border border-[var(--color-border-light)] group">
                <summary class="font-medium text-[var(--color-ink)] cursor-pointer list-none flex items-center justify-between">
                  {faq.question}
                  <svg class="w-5 h-5 text-[var(--color-text-light)] group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                </summary>
                <p class="mt-3 text-[var(--color-text-muted)] leading-relaxed">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
