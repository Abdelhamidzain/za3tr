---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/recipe/RecipeCard.astro';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;
let page: any = null;
let recipes: any[] = [];

try {
  const { data } = await supabase.from('serve_with_pages').select('*').eq('slug', slug!).single();
  page = data;
  if (page?.related_recipe_ids?.length > 0) {
    const { data: rData } = await supabase.from('recipes').select('id,slug,title_en,title_jp,hero_image_url,category,difficulty,total_time').in('id', page.related_recipe_ids).eq('status', 'published');
    recipes = rData || [];
  }
} catch (e) {}

if (!page) return Astro.redirect('/404');
---

<BaseLayout title={`What to Serve with ${page.dish_name}`} description={`Discover the best side dishes and pairings for ${page.dish_name}. Complete your Japanese meal.`}>
  <article class="py-12 md:py-16">
    <div class="container content-width">
      <nav class="flex items-center gap-2 text-sm text-[var(--color-text-light)] mb-6">
        <a href="/" class="hover:text-[var(--color-terracotta)]">Home</a><span>/</span>
        <span class="text-[var(--color-text-muted)]">What to Serve With</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">What to Serve with {page.dish_name}</h1>
      {page.content_en && <div class="mt-8 prose prose-lg max-w-none text-[var(--color-text)] leading-relaxed whitespace-pre-line">{page.content_en}</div>}
      {recipes.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)] mb-6">Recommended Pairings</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {recipes.map(r => <RecipeCard slug={r.slug} title={r.title_en} titleJp={r.title_jp} image={r.hero_image_url} category={r.category} difficulty={r.difficulty} totalTime={r.total_time} />)}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
