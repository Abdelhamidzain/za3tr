---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/recipe/RecipeCard.astro';
import { supabase } from '../../lib/supabase';

const category = Astro.url.searchParams.get('category') || '';
const categories = ['ramen', 'sushi', 'tempura', 'donburi', 'curry', 'noodles', 'desserts', 'appetizers', 'side-dish', 'soup', 'rice', 'drinks'];

let recipes: any[] = [];
try {
  let query = supabase.from('recipes').select('*').eq('status', 'published').order('published_at', { ascending: false });
  if (category && categories.includes(category)) {
    query = query.eq('category', category);
  }
  const { data } = await query;
  recipes = data || [];
} catch (e) {}

const pageTitle = category ? `${category.charAt(0).toUpperCase() + category.slice(1)} Recipes` : 'All Recipes';
---

<BaseLayout title={pageTitle} description={`Browse our collection of authentic Japanese ${category || ''} recipes.`}>
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="mb-10">
        <p class="text-sm text-[var(--color-clay)] font-medium tracking-widest uppercase mb-2">Collection</p>
        <h1 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">
          {pageTitle}
        </h1>
        <p class="text-[var(--color-text-muted)] mt-2">
          {recipes.length > 0 ? `${recipes.length} authentic Japanese recipes` : 'Our collection is growing — check back soon!'}
        </p>
      </div>

      <!-- Filter Bar -->
      <div class="flex flex-wrap gap-2 mb-8 pb-6 border-b border-[var(--color-border-light)]">
        <a href="/recipes/" class:list={["px-4 py-2 rounded-full text-sm font-medium transition-colors", !category ? 'bg-[var(--color-terracotta)] text-white' : 'text-[var(--color-text-muted)] bg-[var(--color-sand)] hover:bg-[var(--color-sand-dark)]']}>
          All
        </a>
        {categories.filter(c => ['ramen','sushi','tempura','donburi','curry','noodles','desserts','appetizers','side-dish','soup'].includes(c)).map(cat => (
          <a href={`/recipes/?category=${cat}`} class:list={["px-4 py-2 rounded-full text-sm font-medium transition-colors", category === cat ? 'bg-[var(--color-terracotta)] text-white' : 'text-[var(--color-text-muted)] bg-[var(--color-sand)] hover:bg-[var(--color-sand-dark)]']}>
            {cat.charAt(0).toUpperCase() + cat.slice(1).replace('-', ' ')}
          </a>
        ))}
      </div>

      {recipes.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {recipes.map(recipe => (
            <RecipeCard
              slug={recipe.slug}
              title={recipe.title_en}
              titleJp={recipe.title_jp}
              image={recipe.hero_image_url}
              category={recipe.category}
              difficulty={recipe.difficulty}
              totalTime={recipe.total_time}
              avgRating={recipe.avg_rating}
              reviewCount={recipe.review_count}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-[var(--color-sand)]/30 rounded-2xl border-2 border-dashed border-[var(--color-border)]">
          <p class="text-5xl mb-4">🍳</p>
          <h2 class="text-xl font-bold font-[family-name:var(--font-display)]">
            {category ? `No ${category} recipes yet` : 'Recipes Coming Soon'}
          </h2>
          <p class="text-[var(--color-text-muted)] mt-2">We're preparing authentic Japanese recipes for you.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
