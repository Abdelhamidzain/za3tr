---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

let guides: any[] = [];
try {
  const { data } = await supabase.from('technique_guides').select('*').eq('status', 'published').order('title_en');
  guides = data || [];
} catch (e) {}
---

<BaseLayout title="Japanese Cooking Techniques" description="Master essential Japanese cooking techniques with our step-by-step guides.">
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="mb-10">
        <p class="text-sm text-[var(--color-clay)] font-medium tracking-widest uppercase mb-2">Learn</p>
        <h1 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">Cooking Techniques</h1>
        <p class="text-[var(--color-text-muted)] mt-2 max-w-2xl">Master the fundamental techniques behind Japanese cuisine.</p>
      </div>
      {guides.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {guides.map(g => (
            <a href={`/techniques/${g.slug}`} class="recipe-card block bg-white rounded-2xl overflow-hidden shadow-[var(--shadow-sm)] border border-[var(--color-border-light)]">
              {g.image_url && <img src={g.image_url} alt={g.title_en} class="w-full aspect-video object-cover" loading="lazy" />}
              <div class="p-5">
                {g.difficulty && <span class:list={["tag mb-2", g.difficulty === 'beginner' ? 'tag-difficulty-beginner' : g.difficulty === 'intermediate' ? 'tag-difficulty-intermediate' : 'tag-difficulty-advanced']}>{g.difficulty}</span>}
                <h2 class="text-lg font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">{g.title_en}</h2>
                {g.title_jp && <p class="text-sm text-[var(--color-text-light)] text-jp mt-0.5">{g.title_jp}</p>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-[var(--color-sand)]/30 rounded-2xl border-2 border-dashed border-[var(--color-border)]">
          <p class="text-5xl mb-4">🔪</p>
          <h2 class="text-xl font-bold font-[family-name:var(--font-display)]">Technique Guides Coming Soon</h2>
          <p class="text-[var(--color-text-muted)] mt-2">Learn knife skills, dashi making, rice cooking and more.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
