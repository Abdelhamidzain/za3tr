---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/recipe/RecipeCard.astro';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;
let guide: any = null;
let relatedRecipes: any[] = [];

try {
  const { data } = await supabase.from('technique_guides').select('*').eq('slug', slug!).single();
  guide = data;
  if (guide?.related_recipe_ids?.length > 0) {
    const { data: rData } = await supabase.from('recipes').select('id,slug,title_en,title_jp,hero_image_url,category,difficulty,total_time').in('id', guide.related_recipe_ids).eq('status', 'published');
    relatedRecipes = rData || [];
  }
} catch (e) {}

if (!guide) return Astro.redirect('/404');
---

<BaseLayout title={`${guide.title_en} — Technique Guide`} description={guide.content_en?.slice(0, 160)}>
  <article class="py-12 md:py-16">
    <div class="container content-width">
      <nav class="flex items-center gap-2 text-sm text-[var(--color-text-light)] mb-6">
        <a href="/" class="hover:text-[var(--color-terracotta)]">Home</a><span>/</span>
        <a href="/techniques" class="hover:text-[var(--color-terracotta)]">Techniques</a><span>/</span>
        <span class="text-[var(--color-text-muted)]">{guide.title_en}</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">{guide.title_en}</h1>
      {guide.title_jp && <p class="text-lg text-[var(--color-text-muted)] text-jp mt-1">{guide.title_jp}</p>}
      {guide.image_url && <img src={guide.image_url} alt={guide.title_en} class="w-full rounded-2xl mt-8 aspect-video object-cover" />}
      {guide.content_en && <div class="mt-8 prose prose-lg max-w-none text-[var(--color-text)] leading-relaxed whitespace-pre-line">{guide.content_en}</div>}
      {relatedRecipes.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)] mb-6">Recipes Using This Technique</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {relatedRecipes.map(r => <RecipeCard slug={r.slug} title={r.title_en} titleJp={r.title_jp} image={r.hero_image_url} category={r.category} difficulty={r.difficulty} totalTime={r.total_time} />)}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
