---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <section class="py-24 md:py-36 text-center">
    <div class="container">
      <p class="text-7xl mb-6">🍙</p>
      <h1 class="text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">404 — Lost in the Kitchen</h1>
      <p class="text-lg text-[var(--color-text-muted)] mt-4 max-w-md mx-auto">
        This page doesn't exist. Perhaps the recipe you're looking for is somewhere else?
      </p>
      <a href="/" class="inline-flex items-center gap-2 mt-8 px-6 py-3 bg-[var(--color-terracotta)] text-white font-medium rounded-xl hover:bg-[var(--color-terracotta-dark)] transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
