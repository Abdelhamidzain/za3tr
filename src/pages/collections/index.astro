---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

let collections: any[] = [];
try {
  const { data } = await supabase.from('collection_pages').select('*').eq('status', 'published');
  collections = data || [];
} catch (e) {}
---

<BaseLayout title="Recipe Collections" description="Curated Japanese recipe collections, meal plans, and seasonal cooking guides.">
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="mb-10">
        <p class="text-sm text-[var(--color-clay)] font-medium tracking-widest uppercase mb-2">Curated</p>
        <h1 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">Recipe Collections</h1>
      </div>
      {collections.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {collections.map(c => (
            <a href={`/collections/${c.slug}`} class="recipe-card block bg-white rounded-2xl overflow-hidden shadow-[var(--shadow-sm)] border border-[var(--color-border-light)] p-6">
              <span class="tag text-xs bg-[var(--color-sand)] text-[var(--color-clay-dark)] capitalize">{c.type}</span>
              <h2 class="text-xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)] mt-3">{c.title_en}</h2>
              {c.description_en && <p class="text-sm text-[var(--color-text-muted)] mt-2">{c.description_en}</p>}
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-[var(--color-sand)]/30 rounded-2xl border-2 border-dashed border-[var(--color-border)]">
          <p class="text-5xl mb-4">📚</p>
          <h2 class="text-xl font-bold font-[family-name:var(--font-display)]">Collections Coming Soon</h2>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
