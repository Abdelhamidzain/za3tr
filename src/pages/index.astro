---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/recipe/RecipeCard.astro';
import { supabase } from '../lib/supabase';

let recipes: any[] = [];
let categories: Record<string, number> = {};

try {
  // Run both queries in parallel + select only needed columns
  const [recipesRes, catRes] = await Promise.all([
    supabase
      .from('recipes')
      .select('slug, title_en, title_jp, hero_image_url, category, difficulty, total_time, avg_rating, review_count')
      .eq('status', 'published')
      .order('published_at', { ascending: false })
      .limit(12),
    supabase
      .from('recipes')
      .select('category')
      .eq('status', 'published')
  ]);
  
  recipes = recipesRes.data || [];
  const catData = catRes.data || [];
  catData.forEach((r: any) => { if (r.category) categories[r.category] = (categories[r.category] || 0) + 1; });
} catch (e) {}

const categoryData = [
  { name: 'Ramen', slug: 'ramen', emoji: '🍜', image: '/images/cat-ramen.jpg', desc: 'Rich broths & handmade noodles' },
  { name: 'Sushi', slug: 'sushi', emoji: '🍣', image: '/images/cat-sushi.jpg', desc: 'From nigiri to creative rolls' },
  { name: 'Tempura', slug: 'tempura', emoji: '🍤', image: '/images/cat-tempura.jpg', desc: 'Perfectly crispy every time' },
  { name: 'Donburi', slug: 'donburi', emoji: '🍚', image: '/images/cat-donburi.jpg', desc: 'Hearty rice bowl classics' },
  { name: 'Curry', slug: 'curry', emoji: '🍛', image: '/images/cat-curry.jpg', desc: 'Japanese comfort food' },
  { name: 'Noodles', slug: 'noodles', emoji: '🍝', image: '/images/cat-noodles.jpg', desc: 'Udon, soba & yakisoba' },
  { name: 'Desserts', slug: 'desserts', emoji: '🍡', image: '/images/cat-desserts.jpg', desc: 'Mochi, matcha & more' },
  { name: 'Appetizers', slug: 'appetizers', emoji: '🥟', image: '/images/cat-appetizers.jpg', desc: 'Gyoza, edamame & izakaya bites' },
];

---

<BaseLayout title="Home">

  <!-- ===== HERO SECTION ===== -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[var(--color-cream)] via-[var(--color-sand)] to-[var(--color-cream-dark)]">
    <!-- Decorative circles -->
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-[var(--color-terracotta)]/5 blur-3xl"></div>
    <div class="absolute -bottom-10 -left-10 w-60 h-60 rounded-full bg-[var(--color-clay)]/8 blur-2xl"></div>
    
    <div class="container relative py-20 md:py-28 lg:py-36">
      <div class="max-w-2xl">
        <!-- Japanese decorative text -->
        <p class="text-jp text-sm tracking-[0.3em] text-[var(--color-clay)] mb-4 uppercase">
          日本料理 — Nihon Ryōri
        </p>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)] leading-[1.1] tracking-tight">
          Master Japanese<br/>
          <span class="text-[var(--color-terracotta)]">Cooking</span> at Home
        </h1>
        
        <p class="mt-6 text-lg text-[var(--color-text-muted)] max-w-lg leading-relaxed">
          Authentic recipes with step-by-step guidance. From comforting ramen bowls to delicate sushi — bring the flavors of Japan to your kitchen.
        </p>
        
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="/recipes" class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-terracotta)] text-white font-medium rounded-xl hover:bg-[var(--color-terracotta-dark)] transition-colors shadow-lg shadow-[var(--color-terracotta)]/20">
            Browse Recipes
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/techniques" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-[var(--color-ink)] font-medium rounded-xl hover:bg-[var(--color-sand)] transition-colors border border-[var(--color-border)]">
            Learn Techniques
          </a>
        </div>
        
        <!-- Stats -->
        <div class="flex items-center gap-8 mt-12 pt-8 border-t border-[var(--color-border)]">
          <div>
            <p class="text-2xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">{recipes.length || '500+'}</p>
            <p class="text-xs text-[var(--color-text-light)] uppercase tracking-wider">Recipes</p>
          </div>
          <div>
            <p class="text-2xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">8</p>
            <p class="text-xs text-[var(--color-text-light)] uppercase tracking-wider">Categories</p>
          </div>
          <div>
            <p class="text-2xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">2</p>
            <p class="text-xs text-[var(--color-text-light)] uppercase tracking-wider">Languages</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="wave-divider"></div>

  <!-- ===== CATEGORIES SECTION ===== -->
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="text-center mb-12">
        <p class="text-sm text-[var(--color-clay)] font-medium tracking-widest uppercase mb-2">Explore</p>
        <h2 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">
          Recipe Categories
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {categoryData.map(cat => (
          <a 
            href={`/recipes?category=${cat.slug}`}
            class="group relative aspect-[4/3] rounded-2xl overflow-hidden bg-[var(--color-sand)] border border-[var(--color-border-light)] hover:shadow-[var(--shadow-warm)] transition-all duration-300"
          >
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-ink)]/70 via-[var(--color-ink)]/20 to-transparent z-10"></div>
            
            <!-- Emoji placeholder (replaced with real images later) -->
            <div class="absolute inset-0 flex items-center justify-center text-6xl opacity-30 group-hover:scale-110 transition-transform duration-500">
              {cat.emoji}
            </div>
            
            <!-- Content -->
            <div class="absolute bottom-0 left-0 right-0 p-4 z-20">
              <h3 class="text-white font-bold font-[family-name:var(--font-display)] text-lg">
                {cat.name}
              </h3>
              <p class="text-white/70 text-xs mt-0.5">
                {cat.desc}
              </p>
              {categories[cat.slug] && (
                <span class="inline-block mt-2 px-2 py-0.5 bg-white/20 backdrop-blur-sm rounded-full text-xs text-white">
                  {categories[cat.slug]} recipes
                </span>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== LATEST RECIPES ===== -->
  <section class="py-16 md:py-24 bg-white/50">
    <div class="container">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-sm text-[var(--color-clay)] font-medium tracking-widest uppercase mb-2">Fresh from the kitchen</p>
          <h2 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">
            Latest Recipes
          </h2>
        </div>
        <a href="/recipes" class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-[var(--color-terracotta)] hover:underline">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      {recipes.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {recipes.map(recipe => (
            <RecipeCard
              slug={recipe.slug}
              title={recipe.title_en}
              titleJp={recipe.title_jp}
              image={recipe.hero_image_url}
              category={recipe.category}
              difficulty={recipe.difficulty}
              totalTime={recipe.total_time}
              avgRating={recipe.avg_rating}
              reviewCount={recipe.review_count}
            />
          ))}
        </div>
      ) : (
        <!-- Placeholder when no recipes yet -->
        <div class="text-center py-16 bg-[var(--color-sand)]/30 rounded-2xl border-2 border-dashed border-[var(--color-border)]">
          <p class="text-5xl mb-4">🍣</p>
          <h3 class="text-xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">
            Recipes Coming Soon
          </h3>
          <p class="text-[var(--color-text-muted)] mt-2 max-w-md mx-auto">
            We're preparing authentic Japanese recipes. Check back soon for our growing collection.
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- ===== WHY ZA3TR ===== -->
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-[var(--color-ink)]">
          Why Za3tr?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center p-6">
          <div class="w-14 h-14 rounded-2xl bg-[var(--color-sand)] flex items-center justify-center mx-auto mb-4 text-2xl">
            🎌
          </div>
          <h3 class="font-bold font-[family-name:var(--font-display)] text-lg text-[var(--color-ink)] mb-2">Authentic Recipes</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            Every recipe is researched for authenticity with cultural context and proper technique.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="w-14 h-14 rounded-2xl bg-[var(--color-sand)] flex items-center justify-center mx-auto mb-4 text-2xl">
            📖
          </div>
          <h3 class="font-bold font-[family-name:var(--font-display)] text-lg text-[var(--color-ink)] mb-2">Step-by-Step</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            Clear instructions with photos for each step. Perfect for beginners and experts alike.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="w-14 h-14 rounded-2xl bg-[var(--color-sand)] flex items-center justify-center mx-auto mb-4 text-2xl">
            🌏
          </div>
          <h3 class="font-bold font-[family-name:var(--font-display)] text-lg text-[var(--color-ink)] mb-2">Bilingual</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            Available in English and Japanese. Each version crafted for its audience, not just translated.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
